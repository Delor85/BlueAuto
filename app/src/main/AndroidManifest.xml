<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.profitloop.blueauto">

    <uses-permission android:android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:android:name="android.permission.READ_SMS" />
    <uses-permission android:android:name="android.permission.SEND_SMS" />
    <uses-permission android:android:name="android.permission.CALL_PHONE" />
    <uses-permission android:android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="BlueAuto"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
        
        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver android:name=".SmsReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
